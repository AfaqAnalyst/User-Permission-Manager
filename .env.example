# ════════════════════════════════════════════
# Tableau RLS Manager — Environment Config
# ════════════════════════════════════════════
# Copy this file to .env and fill in your values

# Oracle DB Connection
DB_USER=your_oracle_username
DB_PASSWORD=your_oracle_password
DB_HOST=your_oracle_server_ip
DB_PORT=1521
DB_SERVICE=your_service_name_or_SID

# Server
PORT=3000
NODE_ENV=production

# App
APP_SECRET=change_this_to_random_string_32chars
